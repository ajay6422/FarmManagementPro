<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/background"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <ImageView
        android:id="@+id/ivLock"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/lock"
        android:contentDescription="Lock Icon"
        android:tint="@color/textColor" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter PIN"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="@font/bold"
        android:textColor="@color/textColor"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="28dp"
        android:text="Protect your important data"
        android:textSize="15sp"
        android:fontFamily="@font/semibold"
        android:textColor="@color/textColor"
        android:alpha="0.7"
        android:gravity="center" />

    <LinearLayout
        android:id="@+id/dotsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <ImageView
            android:id="@+id/dot1"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="8dp"
            android:src="@drawable/dot_empty"
            android:contentDescription="PIN dot 1" />

        <ImageView
            android:id="@+id/dot2"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="8dp"
            android:src="@drawable/dot_empty"
            android:contentDescription="PIN dot 2" />

        <ImageView
            android:id="@+id/dot3"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="8dp"
            android:src="@drawable/dot_empty"
            android:contentDescription="PIN dot 3" />

        <ImageView
            android:id="@+id/dot4"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="8dp"
            android:src="@drawable/dot_empty"
            android:contentDescription="PIN dot 4" />

        <ImageView
            android:id="@+id/dot5"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="8dp"
            android:src="@drawable/dot_empty"
            android:contentDescription="PIN dot 5" />

        <ImageView
            android:id="@+id/dot6"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="8dp"
            android:src="@drawable/dot_empty"
            android:contentDescription="PIN dot 6" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/keypadLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:rowCount="4"
        android:columnCount="3"
        android:useDefaultMargins="true"
        android:alignmentMode="alignMargins">

        <TextView
            android:id="@+id/key1"
            style="@style/PinKey"
            android:text="1" />

        <TextView
            android:id="@+id/key2"
            style="@style/PinKey"
            android:text="2" />

        <TextView
            android:id="@+id/key3"
            style="@style/PinKey"
            android:text="3" />

        <TextView
            android:id="@+id/key4"
            style="@style/PinKey"
            android:text="4" />

        <TextView
            android:id="@+id/key5"
            style="@style/PinKey"
            android:text="5" />

        <TextView
            android:id="@+id/key6"
            style="@style/PinKey"
            android:text="6" />

        <TextView
            android:id="@+id/key7"
            style="@style/PinKey"
            android:text="7" />

        <TextView
            android:id="@+id/key8"
            style="@style/PinKey"
            android:text="8" />

        <TextView
            android:id="@+id/key9"
            style="@style/PinKey"
            android:text="9" />

        <ImageView
            android:id="@+id/btnBiometric"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="6dp"
            android:padding="20dp"
            android:background="@drawable/pin_key_bg"
            android:src="@drawable/ic_fingerprint"
            android:contentDescription="Use biometric"
            android:tint="@color/textColor" />

        <TextView
            android:id="@+id/key0"
            style="@style/PinKey"
            android:text="0" />

        <ImageView
            android:id="@+id/keyDelete"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="6dp"
            android:padding="20dp"
            android:background="@drawable/pin_key_bg"
            android:src="@drawable/ic_backspace"
            android:contentDescription="Delete PIN digit"
            android:tint="@color/textColor" />
    </GridLayout>

    <TextView
        android:id="@+id/tvForgotPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Forgot PIN?"
        android:textSize="15sp"
        android:fontFamily="@font/semibold"
        android:textColor="@color/textColor" />

</LinearLayout>