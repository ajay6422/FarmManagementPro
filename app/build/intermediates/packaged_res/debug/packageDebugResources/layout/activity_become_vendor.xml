<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F4F7F9">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <TextView
            android:text="Become a Vendor"
            android:textSize="22sp"
            android:fontFamily="@font/bold"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:textColor="@color/textColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Choose a plan to start selling your cattle products"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/textColor"
            android:fontFamily="@font/semibold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- ================= STARTER PLAN ================= -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Starter Plan"
                    android:textColor="@color/textColor"
                    android:fontFamily="@font/semibold"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="₹999 / Month"
                    android:textSize="16sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ List up to 5 Products"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Basic Listing Support"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Dashboard Access"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✖ Featured Tag"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✖ Ads Promotion"/>

                <Button
                    android:text="Select Plan"
                    android:backgroundTint="@color/textColor"
                    android:fontFamily="@font/semibold"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= GROWTH PLAN ================= -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Growth Plan"
                    android:textColor="@color/textColor"
                    android:fontFamily="@font/semibold"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="₹1999 / Month"
                    android:textSize="16sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ List up to 15 Products"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Priority Support"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Dashboard + Analytics"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Featured Tag"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✖ Premium Ads"/>

                <Button
                    android:text="Select Plan"
                    android:backgroundTint="@color/textColor"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/semibold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= PREMIUM PLAN ================= -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Premium Plan"
                    android:textColor="@color/textColor"
                    android:fontFamily="@font/semibold"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="₹3499 / Month"
                    android:textSize="16sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Unlimited Products"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Premium Support"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Advanced Analytics"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Featured Tag (Top)"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Ads Promotion"/>

                <Button
                    android:text="Select Plan"
                    android:backgroundTint="@color/textColor"
                    android:fontFamily="@font/semibold"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
